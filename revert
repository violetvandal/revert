#!/usr/bin/env bash
#
# revert — unified front door for THUG2: Violet Vandal Edition ("Revert" toolkit).
#
# One command for the whole lifecycle:
#   revert doctor                          check prerequisites (read-only)
#   revert setup                           install Wine/DXVK/controller + prefixes
#   revert acquire-game-data --iso|--url   turn YOUR THUG2 copy into the pristine base
#   revert acquire-hq [audio|textures]     fetch the optional HQ audio / textures packs
#   revert build [--fast] [--only a,b]     build the edition (reproducible)
#   revert run <vanilla|qol|online> [...]  launch a lane (--soundtrack, --glyphs, --gpu)
#   revert gui                             launch the click-to-install web UI (no terminal)
#   revert install-desktop                 add an app-menu launcher for the GUI
#   revert calibrate-controller            (Deck) detect + bind the controller pad GUID
#   revert configure-controller            bind ANY controller via THUG2's own Launcher
#   revert tag <image> [...]               make an in-game Create-A-Graphic tag
#   revert update [--check]                update to the latest release + rebuild
#   revert uninstall [--purge]             remove Revert (--purge = also saves/Go/packages)
#   revert status [--json]                 report lifecycle state (used by the GUI)
#   revert version                         print the release this checkout is on
#
# Architecture (see docs/ARCHITECTURE.md): a Go "build" core (thugkit) owns producing
# the edition; bash owns launch + system setup. This dispatcher routes to both.
# Config lives in revert.conf (single source of truth).
#
# NOTE: Revert ships TOOLING, never game data — you must own THUG2.
#
set -euo pipefail

# ---- macOS: hand straight over to the native Go front door -----------------------
# This dispatcher is Linux-specific from top to bottom (GE-Proton, lutris paths, apt/pacman,
# evdev) and cannot even locate itself on a Mac: the line below needs GNU `readlink -f`, and
# macOS ships the BSD readlink, which has no -f. The Mac lane is implemented natively in Go
# (internal/core/mac.go), so exec it before anything else runs.
#
# The Go binary must NOT delegate back here — that would ping-pong forever. It won't:
# delegation is gated on IsLinux(), with a hard guard in DelegateToBash.
if [[ "$(uname -s)" == "Darwin" ]]; then
  # Resolve symlinks by hand. install.sh links this script into ~/.local/bin/revert, and
  # without following that link we would look for the toolkit in ~/.local/bin. GNU's
  # `readlink -f` would do this in one call; BSD readlink (which is what macOS ships) only
  # reads a single link, so walk the chain.
  _src="${BASH_SOURCE[0]}"
  while [[ -L "$_src" ]]; do
    _dir="$(cd -P "$(dirname "$_src")" && pwd)"
    _src="$(readlink "$_src")"
    [[ "$_src" != /* ]] && _src="${_dir}/${_src}"
  done
  _root="$(cd -P "$(dirname "$_src")" && pwd)"
  _bin="${_root}/bin/revert"
  if [[ ! -x "$_bin" ]]; then
    _go="$(command -v go 2>/dev/null || true)"
    for _cand in "$HOME/.local/go/bin/go" /opt/homebrew/bin/go /usr/local/bin/go; do
      [[ -n "$_go" ]] && break
      [[ -x "$_cand" ]] && _go="$_cand"
    done
    [[ -n "$_go" ]] || { echo "revert: Go is required to build the macOS front door (brew install go)" >&2; exit 1; }
    echo "[revert] building the macOS front door (one time)…" >&2
    ( cd "$_root" && "$_go" build -o bin/revert ./cmd/revert ) \
      || { echo "revert: could not build bin/revert" >&2; exit 1; }
  fi
  export REVERT_ROOT="$_root"
  exec "$_bin" "$@"
fi

REVERT_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export REVERT_ROOT
CONF="${REVERT_ROOT}/revert.conf"
[[ -f "$CONF" ]] || { echo "revert: missing config: $CONF" >&2; exit 1; }
# shellcheck disable=SC1090
source "$CONF"
# shellcheck disable=SC1090
[[ -f "${REVERT_ROOT}/share/lib/gpu.sh" ]] && source "${REVERT_ROOT}/share/lib/gpu.sh"

c_blue=$'\033[1;34m'; c_red=$'\033[1;31m'; c_grn=$'\033[1;32m'; c_dim=$'\033[2m'; c_off=$'\033[0m'
log()  { printf '%s[revert]%s %s\n' "$c_blue" "$c_off" "$*"; }
err()  { printf '%s[revert:error]%s %s\n' "$c_red" "$c_off" "$*" >&2; exit 1; }
ok()   { printf '  %s✓%s %s\n' "$c_grn" "$c_off" "$*"; }
bad()  { printf '  %s✗%s %s\n' "$c_red" "$c_off" "$*"; }
note() { printf '  %s· %s%s\n' "$c_dim" "$*" "$c_off"; }

usage() {
  sed -n '3,22p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# ---- doctor: read-only prerequisite checks -------------------------------------
cmd_doctor() {
  local fail=0
  log "Revert doctor — checking prerequisites"
  echo "Wine runtime:"
  [[ -x "$GE_DIR/bin/wine" ]] && ok "GE-Proton ($GE_DIR)" || { bad "GE-Proton missing: $GE_DIR"; fail=1; }
  [[ -d "$PREFIX_MAIN" ]]   && ok "main prefix ($PREFIX_MAIN)"   || note "main prefix not created yet (run: revert setup)"
  [[ -d "$PREFIX_ONLINE" ]] && ok "online prefix ($PREFIX_ONLINE)" || note "online prefix not created (THUG Pro lane)"

  echo "Build toolchain:"
  if [[ -x "$THUGKIT" ]]; then
    local _tkout; _tkout="$("$THUGKIT" 2>&1 || true)"
    if printf '%s' "$_tkout" | grep -q build; then
      ok "thugkit binary has 'build'"
    else
      note "thugkit present but no 'build' subcommand yet (rebuild: revert build)"
    fi
  else
    command -v go >/dev/null && note "thugkit not built yet (will build from source)" || { bad "no thugkit binary and no go toolchain"; fail=1; }
  fi
  command -v python3 >/dev/null && ok "python3 (optional CAS asset steps)" || note "python3 absent (panty/sticker CAS steps skipped)"

  echo "Controller:"
  python3 -c 'import evdev' 2>/dev/null && ok "python3-evdev (trigger bridge)" || note "python3-evdev absent (L2/R2 bridge unavailable)"
  [[ -w /dev/uinput ]] && ok "/dev/uinput writable" || note "/dev/uinput not writable (bridge needs ACL; see revert setup)"

  echo "Graphics:"
  if ! command -v vulkaninfo >/dev/null 2>&1; then
    note "vulkaninfo absent (install vulkan-tools to check which GPU DXVK will use)"
  elif declare -F gpu_advise >/dev/null && gpu_advise note; then
    :   # gpu_advise printed its guidance (multi-GPU / weak driver / active filter)
  else
    ok "GPU selection looks fine (single healthy adapter)"
  fi

  echo "Game data (you must own THUG2):"
  [[ -d "$PRISTINE_DIR/Data/pre" ]] && ok "pristine base ($PRISTINE_DIR)" || note "no pristine base yet (run: revert acquire-game-data)"
  [[ -f "$NOCD_EXE" ]]   && ok "no-CD exe present" || note "no-CD THUG2.exe not present (user-supplied)"
  [[ -f "$WSFIX_ZIP" ]]  && ok "WidescreenFix zip present" || note "WidescreenFix zip not present (user-supplied)"
  [[ -f "$HQ_AUDIO_PACK" ]] && ok "HQ audio pack present" || note "HQ audio pack not present (optional, user-supplied)"

  echo
  (( fail )) && err "doctor found blocking issues above" || log "doctor: ready (notes above are optional/next-step)"
}

# ---- build: produce the edition ------------------------------------------------
# Go core (thugkit build) does the portable, zero-dep work; this bash wrapper does
# the archive extraction (7z) + the optional Python CAS asset post-pass. Supersedes
# the old rebuild-playable.sh.
ensure_thugkit() {
  # thugkit with no args prints usage (containing "build") then exits non-zero; under
  # `set -o pipefail` a bare `thugkit | grep` would surface that non-zero and wrongly
  # judge the binary absent — `|| true` keeps only grep's status. (Without this, a box
  # with a prebuilt binary but no Go toolchain fails the build for no reason.)
  [[ -x "$THUGKIT" ]] && { "$THUGKIT" 2>&1 || true; } | grep -q build && return 0
  command -v go >/dev/null || err "no thugkit binary with 'build', and no go toolchain to build it"
  log "building thugkit (Go core)"
  ( cd "$(dirname "$THUGKIT")" && go build -o "$(basename "$THUGKIT")" ./cmd/thugkit ) || err "thugkit build failed"
}

# Python CAS asset post-pass — the steps that live outside the .ns pipeline and Go
# core (texture recolours, licensed model/deck blobs, stickers). Presence-gated;
# never required for a clean build. Mirrors rebuild-playable.sh apply_cas_asset_mods.
cas_post_pass() {  # $1 = edition dir
  local dir="$1" save="${REVERT_ROOT}/tools/save"
  command -v python3 >/dev/null || { note "python3 absent — skipping CAS asset post-pass"; return 0; }
  # These steps import numpy + Pillow (via png2img). If they're missing, skip cleanly with a
  # one-line note instead of letting each script spew a ModuleNotFoundError traceback — the
  # CAS post-pass is cosmetic and never required for a bootable build. (revert setup installs
  # them; this guards a partial/skipped setup.)
  if ! python3 -c 'import numpy, PIL' 2>/dev/null; then
    note "python numpy/Pillow missing — skipping CAS sticker/recolour pass (install: revert setup, or 'pip install numpy pillow')"
    return 0
  fi
  log "CAS asset post-pass (python)"
  python3 "$save/apply_panty_color.py" "$dir" 130 50 190 || true
  [[ -d "$DECKS_BLOB" ]]  && python3 "$save/apply_deck_pack.py" "$dir" "$DECKS_BLOB" || true
  [[ -d "$PLAYAS_BLOB" ]] && python3 "$save/apply_playas_models.py" "$dir" "$PLAYAS_BLOB" || true
  [[ -d "$save/stickers" ]] && python3 "$save/apply_stickers.py" "$dir" || true
}

# Install the edition's in-game movies (Skatepark Project credits + the MOD OPTIONS
# donation card) into the build. Prebuilt .bik (made from the source mp4 via
# tools/bink/encode_video_bik.sh) so the build needs no Wine/RAD. Presence-gated.
install_credits_movies() {  # $1 = edition dir
  local dir="$1" src="${REVERT_ROOT}/tools/bink/credits" f moved=0
  [[ -d "$src" && -d "$dir/Data/movies/bik" ]] || return 0
  for f in "$src"/*.bik; do
    [[ -e "$f" ]] || continue
    cp -f "$f" "$dir/Data/movies/bik/$(basename "$f")" && moved=1
  done
  (( moved )) && log "installed credits movies -> Data/movies/bik/"
  return 0
}

# Install Violet Vandal's bespoke Select-Skater portrait: a loose .img.xbx dropped into
# Data/images/MainmenuSprites/ (where the game reads the stock ss_* portraits from). The
# vv-skater mod's ns-injects (sprites.qb load array + her profile's select_icon=ss_vv,
# applied by thugkit above) make the game load and draw it. Presence-gated; plain copy,
# no python needed (the .img.xbx is a committed asset, generated by build_vv_portrait.py).
install_vv_portrait() {  # $1 = edition dir
  local dir="$1" asset="${MODS_DIR}/src/vv-skater/assets/ss_vv.img.xbx"
  local dst="$dir/Data/images/MainmenuSprites"
  [[ -f "$asset" && -d "$dst" ]] || return 0
  cp -f "$asset" "$dst/ss_vv.img.xbx" \
    && log "installed Violet Vandal portrait -> Data/images/MainmenuSprites/ss_vv.img.xbx"
  return 0
}

cmd_build() {
  local fast="" lane="qol"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fast) fast="--fast"; shift;;
      --lane) lane="${2:-qol}"; shift 2;;
      --only) BUILD_ONLY="$2"; shift 2;;
      *) shift;;
    esac
  done
  ensure_thugkit

  local edition; case "$lane" in
    qol)     edition="$EDITION_QOL";;
    vanilla) edition="$EDITION_VANILLA";;
    *) err "unknown lane '$lane' (use: qol | vanilla)";;
  esac
  [[ -d "$PRISTINE_DIR/Data/pre" ]] || err "no pristine base ($PRISTINE_DIR) — run: revert acquire-game-data"

  # Full build: extract the HQ audio pack (7z) to a cache, excluding pcm.* (keeps PC dialog).
  local hq_arg=()
  if [[ -z "$fast" && -f "$HQ_AUDIO_PACK" ]]; then
    if command -v 7z >/dev/null; then
      local cache="${REVERT_ROOT}/.revert-cache/hq-audio"
      if [[ ! -d "$cache/Game/Data/streams" ]]; then
        log "extracting HQ audio pack (7z, excluding pcm.*)"
        mkdir -p "$cache"
        7z x -y -o"$cache" "$HQ_AUDIO_PACK" -x'!*pcm.wad' -x'!*pcm.dat' >/dev/null || err "7z extract failed"
      fi
      hq_arg=(--hq-audio "$cache")
    else
      note "7z not found — skipping HQ audio overlay"
    fi
  fi

  local only_arg=(); [[ -n "${BUILD_ONLY:-}" ]] && only_arg=(--only "$BUILD_ONLY")
  local wsfix_arg=(); [[ -f "$WSFIX_ZIP" ]] && wsfix_arg=(--wsfix "$WSFIX_ZIP")
  local nocd_arg=();  [[ -f "$NOCD_EXE" ]] && nocd_arg=(--no-cd "$NOCD_EXE")
  local hud_arg=();   [[ -f "$HUDFIX_ASI" ]] && hud_arg=(--hudfix "$HUDFIX_ASI")
  local glyph_arg=(); [[ -f "${GLYPHFIX_ASI:-}" ]] && glyph_arg=(--glyphfix "$GLYPHFIX_ASI")
  local kbd_arg=();   [[ -f "${KEYBOARDGRID_ASI:-}" ]] && kbd_arg=(--keyboardgrid "$KEYBOARDGRID_ASI")
  local tags_arg=();  [[ -d "$TAGS_DIR" ]] && tags_arg=(--tags "$TAGS_DIR")

  log "build lane=$lane${fast:+ (fast)} -> $edition"
  "$THUGKIT" build "$edition" --pristine "$PRISTINE_DIR" --mods "$MODS_DIR" \
    $fast "${nocd_arg[@]}" "${wsfix_arg[@]}" "${hq_arg[@]}" "${hud_arg[@]}" \
    "${glyph_arg[@]}" "${kbd_arg[@]}" "${tags_arg[@]}" "${only_arg[@]}" || err "thugkit build failed"

  cas_post_pass "$edition"
  install_credits_movies "$edition"
  install_vv_portrait "$edition"
  log "build done. Play: revert run $lane"
}

