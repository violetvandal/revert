# ---- gui: build (once) + launch the local web-UI installer ---------------------
cmd_gui() {
  local dir="${REVERT_ROOT}/gui" bin="${REVERT_ROOT}/gui/revert-gui"
  # Build when the binary is missing OR when any Go/web source is newer than it. The
  # staleness check matters: the GUI embeds gui/web/ at compile time, so after an update
  # or `git pull` a prebuilt binary would silently keep serving the OLD UI (this is how a
  # stale binary shipped the pre-fix install wizard). Rebuild only needs Go; with no Go
  # toolchain we fall back to running whatever binary exists.
  local need_build=""
  if [[ ! -x "$bin" ]]; then
    need_build=1
  elif command -v go >/dev/null && \
       [[ -n "$(find "$dir" \( -name '*.go' -o -path '*/web/*' \) -newer "$bin" -print -quit 2>/dev/null)" ]]; then
    need_build=1
  fi
  if [[ -n "$need_build" ]]; then
    command -v go >/dev/null || err "the GUI needs Go to build once (or a prebuilt gui/revert-gui). Install Go, or use the CLI: revert doctor|setup|build|run."
    log "building the GUI ..."
    ( cd "$dir" && go build -o revert-gui . ) || err "GUI build failed"
  fi
  exec "$bin" "$@"
}

# ---- install-desktop: app-menu launcher for the GUI (Linux desktop / Deck) ------
# Writes a .desktop into ~/.local/share/applications so "THUG2: Violet Vandal Edition"
# appears in the app menu and launches the GUI with no terminal. Absolute paths are
# stamped from REVERT_ROOT, so it works wherever the toolkit was cloned.
cmd_install_desktop() {
  local apps="${HOME}/.local/share/applications"
  local dest="${apps}/thug2-violet-vandal.desktop"
  local icon="${REVERT_ROOT}/tools/deck/art/icon.png"
  [[ -f "$icon" ]] || icon="input-gaming"
  mkdir -p "$apps"
  # Pre-build the GUI so the first click launches instantly (best-effort; non-fatal).
  if [[ ! -x "${REVERT_ROOT}/gui/revert-gui" ]] && command -v go >/dev/null; then
    ( cd "${REVERT_ROOT}/gui" && go build -o revert-gui . ) >/dev/null 2>&1 || true
  fi
  cat > "$dest" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=THUG2: Violet Vandal Edition
GenericName=Revert — install & play
Comment=Install, build, and play THUG2: Violet Vandal Edition
Exec=${REVERT_ROOT}/revert gui
Icon=${icon}
Terminal=false
Categories=Game;
Keywords=THUG2;Tony Hawk;Revert;Violet Vandal;skate;
EOF
  chmod +x "$dest"
  command -v update-desktop-database >/dev/null && update-desktop-database "$apps" >/dev/null 2>&1 || true
  log "installed app-menu launcher: $dest"
  note "Look for 'THUG2: Violet Vandal Edition' in your application menu."
  local pn=/sys/devices/virtual/dmi/id/product_name
  if [[ "${SteamDeck:-0}" == "1" ]] || { [[ -r "$pn" ]] && grep -qiE 'jupiter|galileo' "$pn"; }; then
    note "Steam Deck: to launch from Gaming Mode, add ${REVERT_ROOT}/revert to Steam as a non-Steam game with launch options: gui"
  fi
}

# Package the macOS GUI installer as a double-clickable .app inside a .zip. A bare Mach-O
# binary downloaded through a browser loses its execute bit and gains a quarantine flag, so
# Finder treats it as a plain document and opens it in TextEdit — it never realizes it's a
# program. Wrapping it in a proper .app bundle (mirrors writeMacApp in internal/core/mac.go)
# makes Finder recognize it as an application, and shipping it zipped preserves the bundle +
# the executable bit across the download. It's still unsigned, so first launch is a one-time
# right-click -> Open (Gatekeeper), which the install docs already cover.
build_mac_installer_app() {
  local dir="$1" out="$2" goarch="$3" ver="$4"
  command -v zip >/dev/null || err "build-installer needs 'zip' to package the macOS .app."
  local appname="Revert Installer.app" appdir zipname iconkey=""
  appdir="$out/$appname"
  zipname="revert-installer-darwin-${goarch}.zip"
  log "building $zipname ($appname)"
  rm -rf "$appdir"
  mkdir -p "$appdir/Contents/MacOS" "$appdir/Contents/Resources"
  ( cd "$dir" && CGO_ENABLED=0 GOOS=darwin GOARCH="$goarch" \
      go build -trimpath -ldflags='-s -w' -o "$appdir/Contents/MacOS/revert-installer" . ) \
      || return 1
  chmod +x "$appdir/Contents/MacOS/revert-installer"
  # Branded icon, if the .icns is present (same source as the game bundles + Windows .ico).
  if [[ -f "${REVERT_ROOT}/tools/pack/icon/revert.icns" ]]; then
    cp "${REVERT_ROOT}/tools/pack/icon/revert.icns" "$appdir/Contents/Resources/revert.icns"
    iconkey='  <key>CFBundleIconFile</key><string>revert</string>
'
  fi
  cat > "$appdir/Contents/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>Revert Installer</string>
  <key>CFBundleDisplayName</key><string>Revert Installer</string>
  <key>CFBundleIdentifier</key><string>com.violetvandal.revert-installer</string>
  <key>CFBundleExecutable</key><string>revert-installer</string>
${iconkey}  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleShortVersionString</key><string>${ver}</string>
  <key>LSMinimumSystemVersion</key><string>12.0</string>
  <key>NSHighResolutionCapable</key><true/>
</dict>
</plist>
PLIST
  # Zip with the .app as the single top-level entry. -y keeps symlinks; unix perms (the +x on
  # the inner binary) are preserved so the extracted app launches straight away.
  ( cd "$out" && rm -f "$zipname" && zip -q -r -y "$zipname" "$appname" ) || return 1
  rm -rf "$appdir"
  # Drop any stale bare binary from before this packaging change so the dist dir isn't ambiguous.
  rm -f "$out/revert-installer-darwin-${goarch}"
}

# ---- build-installer: cross-compile the standalone GUI installer (maintainer) ---
# Produces one static, dependency-free artifact a beginner can DOWNLOAD and double-click
# to install the whole edition GUI-first (no terminal, no clone — it bootstraps everything).
# Linux/Windows ship a single binary; macOS ships a double-clickable .app inside a .zip (see
# build_mac_installer_app for why). Publish each as a GitHub Release asset. Defaults to
# linux/amd64 (Deck + desktop); pass extra targets like:
#   revert build-installer linux/amd64 windows/amd64 darwin/arm64 darwin/amd64
cmd_build_installer() {
  command -v go >/dev/null || err "build-installer needs the Go toolchain."
  local dir="${REVERT_ROOT}/gui" out="${REVERT_ROOT}/gui/dist"
  mkdir -p "$out"
  local targets=("$@"); [[ ${#targets[@]} -eq 0 ]] && targets=("linux/amd64")
  local ver; ver="$(cmd_version 2>/dev/null || echo dev)"
  local t goos goarch name
  for t in "${targets[@]}"; do
    goos="${t%%/*}"; goarch="${t##*/}"
    if [[ "$goos" == "darwin" ]]; then
      build_mac_installer_app "$dir" "$out" "$goarch" "$ver" || err "build failed for $t"
      continue
    fi
    name="revert-installer-${goos}-${goarch}"; [[ "$goos" == "windows" ]] && name="${name}.exe"
    log "building $name"
    ( cd "$dir" && CGO_ENABLED=0 GOOS="$goos" GOARCH="$goarch" \
        go build -trimpath -ldflags='-s -w' -o "$out/$name" . ) || err "build failed for $t"
  done
  log "installer artifacts in $out:"; ls -1sh "$out"
  note "Upload as a GitHub Release asset; the website /install button links to it."
}

# A Linux install is a git checkout, so the release it's on is whatever git says. (The
# Windows lane has no git and reads a version stamped into revert.exe at build time.)
cmd_version() {
  git -C "$REVERT_ROOT" describe --tags --always 2>/dev/null || echo dev
}

case "${1:-help}" in
  doctor)            shift; cmd_doctor "$@";;
  version|--version) shift; cmd_version "$@";;
  setup)             shift; cmd_setup "$@";;
  acquire-game-data) shift; cmd_acquire "$@";;
  acquire-hq)        shift; cmd_acquire_hq "$@";;
  update)            shift; cmd_update "$@";;
  uninstall)         shift; cmd_uninstall "$@";;
  status)            shift; cmd_status "$@";;
  build)             shift; cmd_build "$@";;
  run)               shift; cmd_run "$@";;
  gui)               shift; cmd_gui "$@";;
  install-desktop)   shift; cmd_install_desktop "$@";;
  build-installer)   shift; cmd_build_installer "$@";;
  calibrate-controller) shift; cmd_calibrate "$@";;
  configure-controller|controls) shift; cmd_configure_controller "$@";;
  tag)               shift; cmd_tag "$@";;
  help|-h|--help)    usage 0;;
  *) echo "revert: unknown command '${1:-}'" >&2; usage 1;;
esac
