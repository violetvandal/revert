#!/usr/bin/env bash
#
# revert — unified front door for THUG2: Violet Vandal Edition ("Revert" toolkit).
#
# One command for the whole lifecycle:
#   revert doctor                          check prerequisites (read-only)
#   revert setup                           install Wine/DXVK/controller + prefixes
#   revert acquire-game-data --iso|--url   turn YOUR THUG2 copy into the pristine base
#   revert acquire-hq [audio|textures]     fetch the optional HQ audio / textures packs
#   revert build [--fast] [--only a,b]     build the edition (reproducible)
#   revert run <vanilla|qol|online> [...]  launch a lane (--soundtrack, --glyphs)
#   revert gui                             launch the click-to-install web UI (no terminal)
#   revert install-desktop                 add an app-menu launcher for the GUI
#   revert calibrate-controller            (Deck) detect + bind the controller pad GUID
#   revert tag <image> [...]               make an in-game Create-A-Graphic tag
#   revert update [--check]                update to the latest release + rebuild
#   revert status [--json]                 report lifecycle state (used by the GUI)
#   revert version                         print the release this checkout is on
#
# Architecture (see docs/ARCHITECTURE.md): a Go "build" core (thugkit) owns producing
# the edition; bash owns launch + system setup. This dispatcher routes to both.
# Config lives in revert.conf (single source of truth).
#
# NOTE: Revert ships TOOLING, never game data — you must own THUG2.
#
set -euo pipefail

REVERT_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export REVERT_ROOT
CONF="${REVERT_ROOT}/revert.conf"
[[ -f "$CONF" ]] || { echo "revert: missing config: $CONF" >&2; exit 1; }
# shellcheck disable=SC1090
source "$CONF"

c_blue=$'\033[1;34m'; c_red=$'\033[1;31m'; c_grn=$'\033[1;32m'; c_dim=$'\033[2m'; c_off=$'\033[0m'
log()  { printf '%s[revert]%s %s\n' "$c_blue" "$c_off" "$*"; }
err()  { printf '%s[revert:error]%s %s\n' "$c_red" "$c_off" "$*" >&2; exit 1; }
ok()   { printf '  %s✓%s %s\n' "$c_grn" "$c_off" "$*"; }
bad()  { printf '  %s✗%s %s\n' "$c_red" "$c_off" "$*"; }
note() { printf '  %s· %s%s\n' "$c_dim" "$*" "$c_off"; }

usage() {
  sed -n '3,21p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# ---- doctor: read-only prerequisite checks -------------------------------------
cmd_doctor() {
  local fail=0
  log "Revert doctor — checking prerequisites"
  echo "Wine runtime:"
  [[ -x "$GE_DIR/bin/wine" ]] && ok "GE-Proton ($GE_DIR)" || { bad "GE-Proton missing: $GE_DIR"; fail=1; }
  [[ -d "$PREFIX_MAIN" ]]   && ok "main prefix ($PREFIX_MAIN)"   || note "main prefix not created yet (run: revert setup)"
  [[ -d "$PREFIX_ONLINE" ]] && ok "online prefix ($PREFIX_ONLINE)" || note "online prefix not created (THUG Pro lane)"

  echo "Build toolchain:"
  if [[ -x "$THUGKIT" ]]; then
    local _tkout; _tkout="$("$THUGKIT" 2>&1 || true)"
    if printf '%s' "$_tkout" | grep -q build; then
      ok "thugkit binary has 'build'"
    else
      note "thugkit present but no 'build' subcommand yet (rebuild: revert build)"
    fi
  else
    command -v go >/dev/null && note "thugkit not built yet (will build from source)" || { bad "no thugkit binary and no go toolchain"; fail=1; }
  fi
  command -v python3 >/dev/null && ok "python3 (optional CAS asset steps)" || note "python3 absent (panty/sticker CAS steps skipped)"

  echo "Controller:"
  python3 -c 'import evdev' 2>/dev/null && ok "python3-evdev (trigger bridge)" || note "python3-evdev absent (L2/R2 bridge unavailable)"
  [[ -w /dev/uinput ]] && ok "/dev/uinput writable" || note "/dev/uinput not writable (bridge needs ACL; see revert setup)"

  echo "Game data (you must own THUG2):"
  [[ -d "$PRISTINE_DIR/Data/pre" ]] && ok "pristine base ($PRISTINE_DIR)" || note "no pristine base yet (run: revert acquire-game-data)"
  [[ -f "$NOCD_EXE" ]]   && ok "no-CD exe present" || note "no-CD THUG2.exe not present (user-supplied)"
  [[ -f "$WSFIX_ZIP" ]]  && ok "WidescreenFix zip present" || note "WidescreenFix zip not present (user-supplied)"
  [[ -f "$HQ_AUDIO_PACK" ]] && ok "HQ audio pack present" || note "HQ audio pack not present (optional, user-supplied)"

  echo
  (( fail )) && err "doctor found blocking issues above" || log "doctor: ready (notes above are optional/next-step)"
}

# ---- build: produce the edition ------------------------------------------------
# Go core (thugkit build) does the portable, zero-dep work; this bash wrapper does
# the archive extraction (7z) + the optional Python CAS asset post-pass. Supersedes
# rebuild-playable.sh (kept as share/legacy reference).
ensure_thugkit() {
  [[ -x "$THUGKIT" ]] && "$THUGKIT" 2>&1 | grep -q build && return 0
  command -v go >/dev/null || err "no thugkit binary with 'build', and no go toolchain to build it"
  log "building thugkit (Go core)"
  ( cd "$(dirname "$THUGKIT")" && go build -o "$(basename "$THUGKIT")" ./cmd/thugkit ) || err "thugkit build failed"
}

# Python CAS asset post-pass — the steps that live outside the .ns pipeline and Go
# core (texture recolours, licensed model/deck blobs, stickers). Presence-gated;
# never required for a clean build. Mirrors rebuild-playable.sh apply_cas_asset_mods.
cas_post_pass() {  # $1 = edition dir
  local dir="$1" save="${REVERT_ROOT}/tools/save"
  command -v python3 >/dev/null || { note "python3 absent — skipping CAS asset post-pass"; return 0; }
  log "CAS asset post-pass (python)"
  python3 "$save/apply_panty_color.py" "$dir" 130 50 190 || true
  [[ -d "$DECKS_BLOB" ]]  && python3 "$save/apply_deck_pack.py" "$dir" "$DECKS_BLOB" || true
  [[ -d "$PLAYAS_BLOB" ]] && python3 "$save/apply_playas_models.py" "$dir" "$PLAYAS_BLOB" || true
  [[ -d "$save/stickers" ]] && python3 "$save/apply_stickers.py" "$dir" || true
}

# Install the edition's in-game movies (Skatepark Project credits + the MOD OPTIONS
# donation card) into the build. Prebuilt .bik (made from the source mp4 via
# tools/bink/encode_video_bik.sh) so the build needs no Wine/RAD. Presence-gated.
install_credits_movies() {  # $1 = edition dir
  local dir="$1" src="${REVERT_ROOT}/tools/bink/credits" f moved=0
  [[ -d "$src" && -d "$dir/Data/movies/bik" ]] || return 0
  for f in "$src"/*.bik; do
    [[ -e "$f" ]] || continue
    cp -f "$f" "$dir/Data/movies/bik/$(basename "$f")" && moved=1
  done
  (( moved )) && log "installed credits movies -> Data/movies/bik/"
  return 0
}

cmd_build() {
  local fast="" lane="qol"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fast) fast="--fast"; shift;;
      --lane) lane="${2:-qol}"; shift 2;;
      --only) BUILD_ONLY="$2"; shift 2;;
      *) shift;;
    esac
  done
  ensure_thugkit

  local edition; case "$lane" in
    qol)     edition="$EDITION_QOL";;
    vanilla) edition="$EDITION_VANILLA";;
    *) err "unknown lane '$lane' (use: qol | vanilla)";;
  esac
  [[ -d "$PRISTINE_DIR/Data/pre" ]] || err "no pristine base ($PRISTINE_DIR) — run: revert acquire-game-data"

  # Full build: extract the HQ audio pack (7z) to a cache, excluding pcm.* (keeps PC dialog).
  local hq_arg=()
  if [[ -z "$fast" && -f "$HQ_AUDIO_PACK" ]]; then
    if command -v 7z >/dev/null; then
      local cache="${REVERT_ROOT}/.revert-cache/hq-audio"
      if [[ ! -d "$cache/Game/Data/streams" ]]; then
        log "extracting HQ audio pack (7z, excluding pcm.*)"
        mkdir -p "$cache"
        7z x -y -o"$cache" "$HQ_AUDIO_PACK" -x'!*pcm.wad' -x'!*pcm.dat' >/dev/null || err "7z extract failed"
      fi
      hq_arg=(--hq-audio "$cache")
    else
      note "7z not found — skipping HQ audio overlay"
    fi
  fi

  local only_arg=(); [[ -n "${BUILD_ONLY:-}" ]] && only_arg=(--only "$BUILD_ONLY")
  local wsfix_arg=(); [[ -f "$WSFIX_ZIP" ]] && wsfix_arg=(--wsfix "$WSFIX_ZIP")
  local nocd_arg=();  [[ -f "$NOCD_EXE" ]] && nocd_arg=(--no-cd "$NOCD_EXE")
  local hud_arg=();   [[ -f "$HUDFIX_ASI" ]] && hud_arg=(--hudfix "$HUDFIX_ASI")
  local glyph_arg=(); [[ -f "${GLYPHFIX_ASI:-}" ]] && glyph_arg=(--glyphfix "$GLYPHFIX_ASI")
  local kbd_arg=();   [[ -f "${KEYBOARDGRID_ASI:-}" ]] && kbd_arg=(--keyboardgrid "$KEYBOARDGRID_ASI")
  local tags_arg=();  [[ -d "$TAGS_DIR" ]] && tags_arg=(--tags "$TAGS_DIR")

  log "build lane=$lane${fast:+ (fast)} -> $edition"
  "$THUGKIT" build "$edition" --pristine "$PRISTINE_DIR" --mods "$MODS_DIR" \
    $fast "${nocd_arg[@]}" "${wsfix_arg[@]}" "${hq_arg[@]}" "${hud_arg[@]}" \
    "${glyph_arg[@]}" "${kbd_arg[@]}" "${tags_arg[@]}" "${only_arg[@]}" || err "thugkit build failed"

  cas_post_pass "$edition"
  install_credits_movies "$edition"
  log "build done. Play: revert run $lane"
}

# ---- run: launch a lane (config-driven, share/run/revert-run.sh) ---------------
cmd_run() {
  local r="${SHARE_DIR}/run/revert-run.sh"
  [[ -x "$r" ]] || err "launcher missing: $r"
  exec "$r" "$@"
}

# ---- tag: passthrough to the Go tool ------------------------------------------
cmd_tag() {
  [[ -x "$THUGKIT" ]] || err "thugkit binary missing ($THUGKIT) — run a build first"
  exec "$THUGKIT" tag "$@"
}

# ---- stubs (implemented in later stages) --------------------------------------
cmd_setup() {
  local s="${SHARE_DIR}/setup/revert-setup.sh"
  [[ -x "$s" ]] && exec "$s" "$@"
  err "revert-setup.sh not present yet (Stage 2). Legacy reference: ${REVERT_ROOT}/install.sh"
}
cmd_acquire() {
  local s="${SHARE_DIR}/setup/revert-acquire.sh"
  [[ -x "$s" ]] && exec "$s" "$@"
  err "acquire-game-data not implemented yet (Stage 4). See game-pristine-us/PRISTINE_README.txt for the manual recipe."
}

# ---- acquire-hq: fetch the optional HQ audio/textures packs (fetch or BYO) ------
cmd_acquire_hq() {
  local s="${SHARE_DIR}/setup/revert-acquire-hq.sh"
  [[ -x "$s" ]] || err "revert-acquire-hq.sh missing or not executable ($s)"
  exec "$s" "$@"
}

# ---- calibrate-controller: (Deck) detect the pad GUID + bind pad0 (run after a build) --
cmd_calibrate() {
  local s="${SHARE_DIR}/setup/revert-calibrate-controller.sh"
  [[ -x "$s" ]] || err "revert-calibrate-controller.sh missing or not executable ($s)"
  exec "$s" "$@"
}

# ---- status: machine-readable lifecycle state (for the GUI) --------------------
# Same signals doctor prints, but as booleans the GUI uses to gate steps. Passive:
# stats paths only, never mutates. `--json` emits one JSON object on stdout.
cmd_status() {
  local wine=false setup=false thugkit=false pristine=false build=false online=false
  [[ -x "$GE_DIR/bin/wine" ]]                    && wine=true
  [[ -d "$PREFIX_MAIN" ]]                        && setup=true
  [[ -x "$THUGKIT" ]] && "$THUGKIT" 2>&1 | grep -q build && thugkit=true
  [[ -d "$PRISTINE_DIR/Data/pre" ]]              && pristine=true
  [[ -d "$EDITION_QOL/Data/pre" ]]               && build=true
  [[ -d "$PREFIX_ONLINE" ]]                      && online=true
  if [[ "${1:-}" == "--json" ]]; then
    printf '{"wine":%s,"setup":%s,"thugkit":%s,"pristine":%s,"build":%s,"online":%s}\n' \
      "$wine" "$setup" "$thugkit" "$pristine" "$build" "$online"
    return 0
  fi
  log "Revert status"
  $wine     && ok "wine runtime"        || bad "wine runtime (run: revert setup)"
  $setup    && ok "main prefix"         || bad "main prefix (run: revert setup)"
  $pristine && ok "pristine game data"  || bad "pristine game data (run: revert acquire-game-data)"
  $build    && ok "edition built"       || bad "edition built (run: revert build)"
  $online   && ok "online prefix"       || note "online prefix (THUG Pro lane, optional)"
}

# ---- update: pull the latest tagged release + rebuild --------------------------
cmd_update() {
  local s="${SHARE_DIR}/setup/revert-update.sh"
  [[ -x "$s" ]] || err "revert-update.sh missing or not executable ($s)"
  exec "$s" "$@"
}

# ---- gui: build (once) + launch the local web-UI installer ---------------------
cmd_gui() {
  local dir="${REVERT_ROOT}/gui" bin="${REVERT_ROOT}/gui/revert-gui"
  if [[ ! -x "$bin" ]]; then
    command -v go >/dev/null || err "the GUI needs Go to build once (or a prebuilt gui/revert-gui). Install Go, or use the CLI: revert doctor|setup|build|run."
    log "building the GUI (one-time) ..."
    ( cd "$dir" && go build -o revert-gui . ) || err "GUI build failed"
  fi
  exec "$bin" "$@"
}

# ---- install-desktop: app-menu launcher for the GUI (Linux desktop / Deck) ------
# Writes a .desktop into ~/.local/share/applications so "THUG2: Violet Vandal Edition"
# appears in the app menu and launches the GUI with no terminal. Absolute paths are
# stamped from REVERT_ROOT, so it works wherever the toolkit was cloned.
cmd_install_desktop() {
  local apps="${HOME}/.local/share/applications"
  local dest="${apps}/thug2-violet-vandal.desktop"
  local icon="${REVERT_ROOT}/tools/deck/art/icon.png"
  [[ -f "$icon" ]] || icon="input-gaming"
  mkdir -p "$apps"
  # Pre-build the GUI so the first click launches instantly (best-effort; non-fatal).
  if [[ ! -x "${REVERT_ROOT}/gui/revert-gui" ]] && command -v go >/dev/null; then
    ( cd "${REVERT_ROOT}/gui" && go build -o revert-gui . ) >/dev/null 2>&1 || true
  fi
  cat > "$dest" <<EOF
[Desktop Entry]
Type=Application
Version=1.0
Name=THUG2: Violet Vandal Edition
GenericName=Revert — install & play
Comment=Install, build, and play THUG2: Violet Vandal Edition
Exec=${REVERT_ROOT}/revert gui
Icon=${icon}
Terminal=false
Categories=Game;
Keywords=THUG2;Tony Hawk;Revert;Violet Vandal;skate;
EOF
  chmod +x "$dest"
  command -v update-desktop-database >/dev/null && update-desktop-database "$apps" >/dev/null 2>&1 || true
  log "installed app-menu launcher: $dest"
  note "Look for 'THUG2: Violet Vandal Edition' in your application menu."
  local pn=/sys/devices/virtual/dmi/id/product_name
  if [[ "${SteamDeck:-0}" == "1" ]] || { [[ -r "$pn" ]] && grep -qiE 'jupiter|galileo' "$pn"; }; then
    note "Steam Deck: to launch from Gaming Mode, add ${REVERT_ROOT}/revert to Steam as a non-Steam game with launch options: gui"
  fi
}

# ---- build-installer: cross-compile the standalone GUI installer (maintainer) ---
# Produces one static, dependency-free binary a beginner can DOWNLOAD and double-click
# to install the whole edition GUI-first (no terminal, no clone — the binary bootstraps
# everything). Publish it as a GitHub Release asset. Defaults to linux/amd64 (Deck +
# desktop); pass extra targets like: revert build-installer linux/amd64 windows/amd64
cmd_build_installer() {
  command -v go >/dev/null || err "build-installer needs the Go toolchain."
  local dir="${REVERT_ROOT}/gui" out="${REVERT_ROOT}/gui/dist"
  mkdir -p "$out"
  local targets=("$@"); [[ ${#targets[@]} -eq 0 ]] && targets=("linux/amd64")
  local t goos goarch name
  for t in "${targets[@]}"; do
    goos="${t%%/*}"; goarch="${t##*/}"
    name="revert-installer-${goos}-${goarch}"; [[ "$goos" == "windows" ]] && name="${name}.exe"
    log "building $name"
    ( cd "$dir" && CGO_ENABLED=0 GOOS="$goos" GOARCH="$goarch" \
        go build -trimpath -ldflags='-s -w' -o "$out/$name" . ) || err "build failed for $t"
  done
  log "installer binaries in $out:"; ls -1sh "$out"
  note "Upload as a GitHub Release asset; the website /install button links to it."
}

# A Linux install is a git checkout, so the release it's on is whatever git says. (The
# Windows lane has no git and reads a version stamped into revert.exe at build time.)
cmd_version() {
  git -C "$REVERT_ROOT" describe --tags --always 2>/dev/null || echo dev
}

case "${1:-help}" in
  doctor)            shift; cmd_doctor "$@";;
  version|--version) shift; cmd_version "$@";;
  setup)             shift; cmd_setup "$@";;
  acquire-game-data) shift; cmd_acquire "$@";;
  acquire-hq)        shift; cmd_acquire_hq "$@";;
  update)            shift; cmd_update "$@";;
  status)            shift; cmd_status "$@";;
  build)             shift; cmd_build "$@";;
  run)               shift; cmd_run "$@";;
  gui)               shift; cmd_gui "$@";;
  install-desktop)   shift; cmd_install_desktop "$@";;
  build-installer)   shift; cmd_build_installer "$@";;
  calibrate-controller) shift; cmd_calibrate "$@";;
  tag)               shift; cmd_tag "$@";;
  help|-h|--help)    usage 0;;
  *) echo "revert: unknown command '${1:-}'" >&2; usage 1;;
esac
