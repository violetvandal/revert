# ---- configure-controller: bind ANY pad via THUG2's own Launcher ----------------
# The universal controller path. XInput-mode pads (Xbox, 8BitDo, most modern pads in
# "X" mode) already work out of the box — setup imports a standard map and the trigger
# bridge is layout-agnostic. But any OTHER pad (a PlayStation controller left in DInput
# mode, an arcade stick, an oddball HID gamepad) can be bound by hand here: Launcher.exe
# is THUG2's own config tool, so it enumerates whatever Wine sees and writes the gp0_*
# map for THAT device. We deliberately don't ship per-controller maps; we let the user
# bind what they have.
#
# The rebind only touches the gamepad map: pad0 is still probed live on each launch, and
# the k0_ numpad keys the trigger bridge injects are left intact.
cmd_configure_controller() {
  [[ -x "$GE_DIR/bin/wine" ]] || err "Wine not installed ($GE_DIR/bin/wine) — run: revert setup"
  [[ -d "$PREFIX_MAIN" ]]     || err "no Wine prefix ($PREFIX_MAIN) — run: revert setup"
  local dir="$EDITION_QOL"
  [[ -f "$dir/Launcher.exe" ]] || dir="$PRISTINE_DIR"
  [[ -f "$dir/Launcher.exe" ]] || err "Launcher.exe not found — build the edition first: revert build"

  log "Opening THUG2's controller config (Launcher.exe)."
  note "Bind each control to your pad, then Save and close the Launcher."
  note "Tip: most controllers 'just work' if switched to XInput / \"X\" mode — this is for the rest."
  # winmm=native (WSFix loader) + dinput8=builtin (so DirectInput enumerates the pad),
  # matching the game launch, or the Launcher won't see the controller.
  cd "$dir"
  WINEPREFIX="$PREFIX_MAIN" WINEDLLOVERRIDES="winmm=n,b;dinput8=b" WINEDEBUG=-all \
    "$GE_DIR/bin/wine" Launcher.exe || true
  log "Controller config saved. Play: revert run qol"
}

# ---- status: machine-readable lifecycle state (for the GUI) --------------------
# Same signals doctor prints, but as booleans the GUI uses to gate steps. Passive:
# stats paths only, never mutates. `--json` emits one JSON object on stdout.
cmd_status() {
  local wine=false setup=false thugkit=false pristine=false build=false online=false
  [[ -x "$GE_DIR/bin/wine" ]]                    && wine=true
  [[ -d "$PREFIX_MAIN" ]]                        && setup=true
  [[ -x "$THUGKIT" ]] && { "$THUGKIT" 2>&1 || true; } | grep -q build && thugkit=true   # || true: pipefail-safe (thugkit usage exits non-zero)
  [[ -d "$PRISTINE_DIR/Data/pre" ]]              && pristine=true
  [[ -d "$EDITION_QOL/Data/pre" ]]               && build=true
  # "online" = THUG Pro actually installed (its launcher exists), matching the Windows
  # thugProInstalled() signal, so the GUI can hide the install card once it's in place.
  [[ -f "$LANE_ONLINE_DIR/THUGProLauncher.exe" ]] && online=true
  if [[ "${1:-}" == "--json" ]]; then
    printf '{"wine":%s,"setup":%s,"thugkit":%s,"pristine":%s,"build":%s,"online":%s}\n' \
      "$wine" "$setup" "$thugkit" "$pristine" "$build" "$online"
    return 0
  fi
  log "Revert status"
  $wine     && ok "wine runtime"        || bad "wine runtime (run: revert setup)"
  $setup    && ok "main prefix"         || bad "main prefix (run: revert setup)"
  $pristine && ok "pristine game data"  || bad "pristine game data (run: revert acquire-game-data)"
  $build    && ok "edition built"       || bad "edition built (run: revert build)"
  $online   && ok "THUG Pro installed"  || note "THUG Pro not installed (online lane, optional: revert setup --online)"
}

