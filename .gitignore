# Violet Vandal "Revert" toolkit — LOCAL repo (no remote/push).
# NEVER track game data, disc images, installs, or external clones.

# Game installs & rips (rebuildable, huge, copyrighted)
game-*/
iso_extracted*/
clean-rip/
THUG2/
THUG2_Win_ROM_EN/
Tony*/
Tony-Hawk*/
THUG2-US-personal-backup*/
pc-tony*/
Custom Skater Renders/
thug2-linux-installer/

# Disc images / archives / big blobs / game binaries
*.iso
*.zip
*.7z
*.tar.zst
*.tar.gz
*.tar.xz
*.sha256
*.pdf
*.exe
*.dll
*.ico
*.url

# ...but our own app icon is a shipped build input, not a ripped game asset. Without this
# the blanket *.ico above drops it from a fresh clone and the packer builds unbranded exes.
!tools/pack/icon/revert.ico

# Same trap for the macOS lane: these two DLLs are OUR OWN build outputs (we patched DXVK
# from source and wrote the dinput8 proxy), not game data, and `revert setup` on a Mac
# installs them into the wine prefix. The blanket *.dll above would drop them from a fresh
# clone and every Mac install would come up with no GPU d3d9 and an inverted left stick.
!tools/dxvk-mac/d3d9-dxvk-patched-m1.dll
!tools/mac-controller/dinput8.dll

# And the DirectInput GUID probe. `revert calibrate-controller` shells out to it on every
# platform and the Windows packer stages it, but *.exe above meant it was never actually in
# the repo -- it only ever worked because an untracked copy happened to sit on the dev box.
!tools/xinput-probe/dinput_probe_guid.exe

# Logs & scratch
*.log
out/
scratch-*/
backups/
**/*.orig

# Separate git repos (own history; not part of Revert)
mods/
thug2-tag-importer/
thug2-skater-extractor/

# External tool clones / upstream forks (not our code)
tools/thugkit/
tools/neverscript/
tools/io_thps_scene/
tools/partymod-src/
tools/leonblade-qb/
tools/wsfp-src/
tools/wsfix/

# Generated / large tool outputs & art payloads
tools/save/renders/
tools/save/grf_work/
tools/save/io_thps_scene/
tools/save/stickers/
tools/bink/rad/
tools/bink/radio/bik/

# Local config override (machine-specific; survives `revert update`)
revert.conf.local

# Revert build cache (extracted HQ pack etc.)
.revert-cache/
__pycache__/
*.pyc

# --- Housekeeping 2026-07-03: exclude local config, game-derived assets & third-party bins ---
# Local Claude Code config (machine-specific; may hold local paths)
.claude/
# Game-derived HQ texture pack (~1GB, copyrighted)
tools/xbox_hq/
# Bink scratch/work (TGA/wav intermediates)
tools/bink/work/
# Royalty-free radio: source audio + compiled variants (bulky/rebuildable; bik/ already ignored)
tools/bink/radio/src/
tools/bink/radio/variants/
# Third-party binaries (not our code)
tools/upscale/realesrgan-ncnn-vulkan-*
tools/partymod/
# Diagnostic .asi binaries (compiled; shipped hudfix/glyphfix already tracked)
*.asi
# Game-derived .qb/.ns work dirs
tools/prx/modmenu-work/
tools/prx/recompiler-grind/

# GUI installer build output
gui/revert-gui
gui/dist/

# macOS front door: the bash `revert` builds this on first use (bash can't run the Mac lane)
/bin/

# Windows bundle output (cross-compiled binaries + zip; rebuildable via tools/pack/)
/dist/

# acquire --url temp workdir (auto-cleaned on graceful exit; lingers if a download is killed)
.revert-acquire.*/

# Uninstall breadcrumbs written by install.sh / revert-setup.sh (record what to purge)
.revert-installed-go
.revert-packages

# Downloaded THUG Pro installer stub (fetched by `revert setup --online`; re-fetched on demand)
.revert-thugpro-setup.exe
