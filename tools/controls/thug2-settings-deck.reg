Windows Registry Editor Version 5.00

; THUG2: Violet Vandal Edition — Steam Deck controller binding (player 1)
; gp0_* = gamepad map for Steam Input's emulated Xbox pad; k0_* = keyboard map
; (the pad-bridge emits KP1/KP7/KP9 for get-off/nollie/switch). pad0 (device GUID)
; is written separately by revert setup via the live pad probe — do NOT hardcode it.
; L3/R3 (gp0_18/gp0_13) account for the Deck pad's extra Guide button.

[HKEY_CURRENT_USER\Software\Activision\Tony Hawk's Underground 2\Settings]
"gp0_0"=dword:00000002
"gp0_1"=dword:00000002
"gp0_2"=dword:00000001
"gp0_3"=dword:00000001
"gp0_4"=dword:00000007
"gp0_5"=dword:00000007
"gp0_6"=dword:00000006
"gp0_7"=dword:00000006
