"gp0_9"=dword:0000000c
"gp0_10"=dword:0000000d
"gp0_11"=dword:0000000e
"gp0_12"=dword:00000012
"gp0_13"=dword:00000015
"gp0_14"=dword:00000000
"gp0_15"=dword:00000000
"gp0_16"=dword:00000000
"gp0_17"=dword:00000000
"gp0_18"=dword:00000014
"gp0_19"=dword:00000000
"gp0_20"=dword:00000005
"gp0_21"=dword:00000005
"gp0_22"=dword:00000004
"gp0_23"=dword:00000004
